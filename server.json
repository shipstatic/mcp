{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "com.shipstatic/mcp",
  "title": "ShipStatic",
  "description": "Static hosting - deploy and manage sites from AI agents",
  "repository": {
    "url": "https://github.com/shipstatic/mcp",
    "source": "github",
    "id": "1171867838"
  },
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/shipstatic/mcp/main/icon.svg",
      "mimeType": "image/svg+xml",
      "sizes": "480x480"
    }
  ],
  "websiteUrl": "https://shipstatic.com",
  "version": "0.1.7",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@shipstatic/mcp",
      "version": "0.1.7",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "SHIP_API_KEY",
          "description": "Your ShipStatic API key",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
